# ── tpass-form 環境變數範本 ──────────────────────────────────────────────
# 複製成 .env.local 填真值（.env.local 不進 git）。所有網域/issuer/audience 一律 env 驅動，不寫死。

# ── SSO 對接（消費端，只需公鑰來源 + 幾個 URL，絕不碰 auth 私鑰）──────
AUTH_JWKS_URL=https://auth.lvh.me:3000/.well-known/jwks.json
AUTH_AUTHORIZE_URL=https://auth.lvh.me:3000/api/auth/authorize
AUTH_LOGOUT_URL=https://auth.lvh.me:3000/api/auth/logout
# 本服務自己的完整網址（callback / 登出導回用）。
FORM_SELF_URL=https://form.lvh.me:3002

# 契約 v2：本服務登記的服務 id（＝ tpass-ops services.json 的 id；須在 auth 的
# AUTH_SERVICE_IDS 白名單內）。驗章 audience = tpass:<此 id>，程式自動派生。
TPASS_SERVICE_ID=form

# 門戶大廳網址（navbar「回門戶」按鈕用）。
# 本機： https://portal.lvh.me:3001   上線： https://portal.tschoolsu.org
PORTAL_URL=https://portal.lvh.me:3001
JWT_ISSUER=https://auth.lvh.me:3000

# ── v1 遷移期 fallback（全生態升到 v2、auth 停發共用 cookie 後可整段移除）──
JWT_AUDIENCE=tschool-sso
TPASS_COOKIE_NAME=tpass_session

# ── Admin 白名單種子（超級管理員，逗號分隔；其餘成員登入後在 /admin/members 用 UI 加）──
SUPER_ADMIN_EMAILS=you@tschool.tp.edu.tw

# ── 資料庫（本機用 tpass db setup 自動建；上線用主機的 per-service user/db）──
DATABASE_URL=postgresql://t_form@localhost:5432/t_form

# ── 匿名防重複用的鹽（隨機長字串；必填——空值會讓匿名雜湊可被反解）──────
ANON_HASH_SECRET=change-me-to-a-long-random-string

# ── 檔案儲存 ──────────────────────────────────────────────────────────
# driver=local：寫到本機 ./.uploads（本機 demo 用，serverless 不持久）。
# driver=s3：填 S3 相容（含 Supabase Storage 的 S3 endpoint）設定。
STORAGE_DRIVER=local
# 以下僅 driver=s3 時需要：
# S3_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
# S3_REGION=ap-northeast-1
# S3_BUCKET=tform-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── HTTPS 本機憑證（tpass setup 產的共用憑證；npm run start:https 讀取）──
TLS_KEY_FILE=../certs/key.pem
TLS_CERT_FILE=../certs/cert.pem
PORT=3002
HOSTNAME=form.lvh.me
