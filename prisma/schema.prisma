// tpass-form 資料模型。表單本體用 JSONB document 存定義（題型多變、要好版本控管，
// 正規化成一堆題目表是自找麻煩）。真相來源是這個 Postgres；Google Sheet 只做匯出鏡像。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 學生會 email 白名單（超管種子來自 env，不入此表）。

model Form {
  id          String     @id @default(cuid())
  slug        String     @unique // 公開連結用，亂數短碼
  title       String
  description String?
  status      String     @default("draft") // draft | published | closed
  ownerSub    String // 建立者 JWT sub（僅供顯示，非門禁；admin 皆可維護所有問卷）
  ownerEmail  String
  definition  Json // 有序 blocks（section_break / text_block / question）
  settings    Json // anonymous / identityFields / theme / cover / acceptingResponses
  version     Int        @default(0) // 樂觀鎖：存檔時 compare-and-swap，擋同時編輯的靜默覆蓋
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  responses   Response[]

  @@index([status])
  @@index([ownerSub])
}

model Response {
  id              String   @id @default(cuid())
  formId          String
  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondentSub   String? // 匿名 → null
  anonHash        String? // 匿名但要防重複時：sha256(sub + formId + secret)
  respondentEmail String?
  respondentName  String?
  respondentGrade Int? // 由 email 推導
  answers         Json // { [questionId]: value }
  submittedAt     DateTime @default(now())

  @@unique([formId, respondentSub])
  @@unique([formId, anonHash])
  @@index([formId])
}

// 檔案上傳：提交前先傳，answers 內存 upload id 參照。
model Upload {
  id          String   @id @default(cuid())
  formId      String
  questionId  String
  storageKey  String // 物件儲存 key
  filename    String
  mime        String
  size        Int
  uploaderSub String
  createdAt   DateTime @default(now())

  @@index([formId])
}
